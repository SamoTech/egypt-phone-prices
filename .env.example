# ─── Database (Supabase) ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
DATABASE_URL_SYNC=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# ─── Supabase API ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Redis (Upstash — free tier at upstash.com) ─────────────────────────────
REDIS_URL=rediss://default:password@region.upstash.io:6379

# ─── Scraping ───────────────────────────────────────────────────────────────
PROXY_LIST=http://user:pass@proxy1:8000,http://user:pass@proxy2:8000
SCRAPLING_STEALTH=true
SCRAPE_DELAY_MIN=2
SCRAPE_DELAY_MAX=6

# ─── Frontend ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://egypt-phones-api.vercel.app

# ─── Admin & Cron ───────────────────────────────────────────────────────────
ADMIN_TOKEN=change-me-to-a-strong-secret
CRON_SECRET=change-me-to-a-strong-secret
