# ─── Database (Supabase) ───────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/egypt_phones
DATABASE_URL_SYNC=postgresql://user:password@host:5432/egypt_phones

# ─── Redis (Upstash — free tier at upstash.com) ──────────────────
REDIS_URL=rediss://default:password@region.upstash.io:6379

# ─── Scraping ──────────────────────────────────────────────
PROXY_LIST=http://user:pass@proxy1:8000,http://user:pass@proxy2:8000
SCRAPLING_STEALTH=true
SCRAPE_DELAY_MIN=2
SCRAPE_DELAY_MAX=6

# ─── Frontend ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Admin ───────────────────────────────────────────────
ADMIN_TOKEN=change-me-to-a-strong-secret
